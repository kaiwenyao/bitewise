# ---- Supabase ----
# 项目 Dashboard → Settings → API Keys →「Publishable and secret API keys」
SUPABASE_URL=https://your-project.supabase.co
# sb_secret_ 密钥(仅服务端使用,切勿暴露到客户端;Legacy 的 service_role 将于 2026 年底停用,勿用)
SUPABASE_SECRET_KEY=sb_secret_your-key

# ---- MiniMax(Token Plan)----
# MiniMax 开放平台 → API 密钥
MINIMAX_API_KEY=sk-your-key
# 国内版 https://api.minimaxi.com;国际版 https://api.minimax.io
MINIMAX_BASE_URL=https://api.minimaxi.com
